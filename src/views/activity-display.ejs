<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Activity - Lesson Craft</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 20px;
    }
    
    .container {
      background: white;
      border-radius: 20px;
      padding: 40px;
      max-width: 800px;
      width: 100%;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    }
    
    h1 {
      color: #667eea;
      margin-bottom: 10px;
      font-size: 2.5em;
      text-align: center;
    }
    
    .subtitle {
      color: #666;
      margin-bottom: 30px;
      font-size: 1.1em;
      text-align: center;
    }
    
    .activity-section {
      margin-bottom: 20px;
    }
    
    .activity-section h4 {
      color: #667eea;
      margin-bottom: 10px;
      font-size: 1.1em;
    }
    
    .activity-section p {
      margin-bottom: 8px;
      line-height: 1.6;
    }
    
    .activity-section ul {
      list-style: none;
      padding-left: 0;
    }
    
    .activity-section li {
      padding: 8px;
      margin-bottom: 5px;
      background: #f9f9f9;
      border-radius: 4px;
    }
    
    .correct-answer {
      color: #27ae60;
      font-weight: bold;
    }
    
    .action-buttons {
      display: flex;
      gap: 15px;
      margin-top: 30px;
    }
    
    .action-buttons button,
    .action-buttons a {
      flex: 1;
      text-decoration: none;
    }
    
    button {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      border: none;
      padding: 14px 30px;
      border-radius: 8px;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      width: 100%;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    
    button:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 20px rgba(102, 126, 234, 0.4);
    }
    
    button:active {
      transform: translateY(0);
    }
    
    button.secondary {
      background: #f5f5f5;
      color: #667eea;
      border: 2px solid #667eea;
    }
    
    button.secondary:hover {
      background: #667eea;
      color: white;
    }
    
    .edit-mode {
      display: none;
    }
    
    .edit-mode.active {
      display: block;
    }
    
    .view-mode.hidden {
      display: none;
    }
    
    textarea.editor {
      width: 100%;
      min-height: 400px;
      padding: 15px;
      border: 2px solid #e0e0e0;
      border-radius: 8px;
      font-size: 14px;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      line-height: 1.6;
      resize: vertical;
      margin-bottom: 15px;
    }
    
    textarea.editor:focus {
      outline: none;
      border-color: #667eea;
    }
    
    .edit-controls {
      display: flex;
      gap: 10px;
      margin-bottom: 20px;
    }
    
    button.edit-btn {
      background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
    }
    
    button.edit-btn:hover {
      box-shadow: 0 10px 20px rgba(245, 87, 108, 0.4);
    }
    
    .pdf-controls {
      display: flex;
      gap: 10px;
      margin-bottom: 20px;
    }
    
    button.pdf-btn {
      background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
    }
    
    button.pdf-btn:hover {
      box-shadow: 0 10px 20px rgba(56, 239, 125, 0.4);
    }
    
    button.download-btn {
      background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
    }
    
    button.download-btn:hover {
      box-shadow: 0 10px 20px rgba(0, 242, 254, 0.4);
    }
    
    .message {
      padding: 15px;
      border-radius: 8px;
      margin-bottom: 20px;
      font-weight: 500;
      display: none;
    }
    
    .message.success {
      background: #d4edda;
      color: #155724;
      border: 1px solid #c3e6cb;
      display: block;
    }
    
    .message.error {
      background: #f8d7da;
      color: #721c24;
      border: 1px solid #f5c6cb;
      display: block;
    }
    
    .message.info {
      background: #d1ecf1;
      color: #0c5460;
      border: 1px solid #bee5eb;
      display: block;
    }
    
    button:disabled {
      opacity: 0.6;
      cursor: not-allowed;
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>🎓 Generated Activity</h1>
    <p class="subtitle">Your lesson activity is ready</p>
    
    <div id="statusMessage" class="message"></div>
    
    <div class="edit-controls">
      <button id="toggleEditBtn" class="edit-btn">✏️ Edit</button>
    </div>
    
    <div class="pdf-controls">
      <button id="generatePdfBtn" class="pdf-btn">📄 Generate PDF</button>
      <button id="downloadPdfBtn" class="download-btn" style="display: none;">⬇️ Download PDF</button>
    </div>
    
    <div id="viewMode" class="view-mode">
      <div id="activityContent">
        <!-- Activity content will be displayed here -->
      </div>
    </div>
    
    <div id="editMode" class="edit-mode">
      <textarea id="activityEditor" class="editor"></textarea>
      <div id="structuredEditor" style="display:none; margin-top:12px;"></div>
      <button id="saveBtn">💾 Save Changes</button>
      <button id="cancelBtn" class="secondary">✖ Cancel</button>
    </div>
    
    <div class="action-buttons">
      <a id="backToSourceLink" href="/image-activity">
        <button id="backToSourceBtn" class="secondary">← Select Another Image</button>
      </a>
      <a href="/">
        <button>🏠 Home</button>
      </a>
    </div>
  </div>
  
  <script>
    function formatActivityContent(content) {
      // Remove markdown code blocks if present
      let cleanContent = content.trim();
      cleanContent = cleanContent.replace(/^```json\s*/i, '');
      cleanContent = cleanContent.replace(/^```\s*/i, '');
      cleanContent = cleanContent.replace(/```\s*$/i, '');
      cleanContent = cleanContent.trim();
      
      try {
        // Try to parse as JSON
        const data = JSON.parse(cleanContent);
        
        let html = '';
        
        // Check for nested structures: tasks, exercises, activity_components, or direct
        const content = data.tasks || data.exercises || data.activity_components || data;
        
        // Multiple Choice Sentences - support multiple field names
        const multiChoice = content.multiple_choice_blanks || content.multiple_choice_sentences || data.multiple_choice_sentences || data.multiple_choice_blanks;
        if (multiChoice && multiChoice.length > 0) {
          html += `<div class="activity-section">
            <ul>`;
          multiChoice.forEach((item, index) => {
            html += `<li>${item.sentence}<br>`;
            html += `<ul style="padding-left: 20px; margin-top: 5px;">`;
            item.options.forEach((option, optIndex) => {
              // Check if correct_option is an index or the actual answer
              let isCorrect = false;
              if (typeof item.correct_option === 'number') {
                isCorrect = optIndex === item.correct_option;
              } else if (typeof item.correct_option === 'string') {
                isCorrect = option === item.correct_option;
              }
              html += `<li style="background: ${isCorrect ? '#d4edda' : 'transparent'}; padding: 4px;">
                ${String.fromCharCode(97 + optIndex)}) ${option}</li>`;
            });
            html += `</ul></li>`;
          });
          html += `</ul></div>`;
        }
        
        // Open Question
        const openQ = content.open_question || data.open_question;
        if (openQ) {
          html += `<div class="activity-section">`;
          if (typeof openQ === 'string') {
            html += `<p>${openQ}</p>`;
          } else if (openQ.question) {
            html += `<p>${openQ.question}</p>`;
            if (openQ.guidance) {
              html += `<p><em>${openQ.guidance}</em></p>`;
            }
          }
          html += `</div>`;
        }
        
        if (!html) {
          // If no sections were generated, show the raw data for debugging
          html = `<div class="activity-section">
            <p><strong>Activity data received but format not recognized.</strong></p>
            <pre style="background: #f9f9f9; padding: 10px; border-radius: 4px; font-size: 12px; max-height: 400px; overflow-y: auto;">${JSON.stringify(data, null, 2)}</pre>
          </div>`;
        }
        
        return html;
      } catch (e) {
        // If not valid JSON, return error with raw content
        console.error('Parse error:', e);
        return `<div class="activity-section">
          <p><strong>Error parsing activity data.</strong></p>
          <pre style="background: #ffe6e6; padding: 10px; border-radius: 4px;">${e.message}</pre>
          <details>
            <summary>Raw content (click to expand)</summary>
            <pre style="font-size: 12px; max-height: 300px; overflow-y: auto;">${cleanContent}</pre>
          </details>
        </div>`;
      }
    }
    
    // Load activity data from sessionStorage
    let activityData = sessionStorage.getItem('activityData');
    let currentData = null;

    function configureBackToSource() {
      const backLink = document.getElementById('backToSourceLink');
      const backBtn = document.getElementById('backToSourceBtn');

      if (!currentData || !currentData.activitySource) {
        backLink.href = '/image-activity';
        backBtn.textContent = '← Select Another Image';
        return;
      }

      if (currentData.activitySource === 'video') {
        backLink.href = '/video-activity';
        backBtn.textContent = '← Try Another Video';
      } else {
        backLink.href = '/image-activity';
        backBtn.textContent = '← Select Another Image';
      }
    }
    
    if (activityData) {
      try {
        currentData = JSON.parse(activityData);
        document.getElementById('activityContent').innerHTML = formatActivityContent(currentData.generatedContent);
        
        // Clear old PDF ID when loading new activity
        // Check if this is a different activity by comparing timestamps
        const lastActivityTimestamp = sessionStorage.getItem('lastActivityTimestamp');
        if (lastActivityTimestamp !== String(currentData.timestamp)) {
          // This is a new activity, clear the old PDF ID
          sessionStorage.removeItem('currentPdfId');
          sessionStorage.setItem('lastActivityTimestamp', currentData.timestamp);
        }

        configureBackToSource();
      } catch (error) {
        document.getElementById('activityContent').innerHTML = `
          <div class="activity-section">
            <p><strong>Error loading activity data.</strong></p>
            <p>${error.message}</p>
          </div>`;
      }
    } else {
      // No data found, redirect to image selection
      window.location.href = '/';
    }
    
    // Convert JSON to human-readable text
    function jsonToText(jsonString) {
      let content = jsonString.trim();
      content = content.replace(/^```json\s*/i, '');
      content = content.replace(/^```\s*/i, '');
      content = content.replace(/```\s*$/i, '');
      content = content.trim();
      
      try {
        const data = JSON.parse(content);
        const activityContent = data.tasks || data.exercises || data.activity_components || data;
        let text = '';
        
        // Multiple choice sentences
        const multiChoice = activityContent.multiple_choice_blanks || activityContent.multiple_choice_sentences || data.multiple_choice_sentences || data.multiple_choice_blanks;
        if (multiChoice && multiChoice.length > 0) {
          text += '=== MULTIPLE CHOICE SENTENCES ===\n\n';
          multiChoice.forEach((item, index) => {
            text += `${index + 1}. ${item.sentence}\n`;
            item.options.forEach((option, optIndex) => {
              const marker = item.correct_option === optIndex ? '[CORRECT]' : '';
              text += `   ${String.fromCharCode(97 + optIndex)}) ${option} ${marker}\n`;
            });
            text += '\n';
          });
        }
        
        // Open question
        const openQ = activityContent.open_question || data.open_question;
        if (openQ) {
          text += '=== OPEN QUESTION ===\n\n';
          if (typeof openQ === 'string') {
            text += openQ + '\n';
          } else if (openQ.question) {
            text += openQ.question + '\n';
            if (openQ.guidance) {
              text += `(Guidance: ${openQ.guidance})\n`;
            }
          }
        }
        
        return text;
      } catch (e) {
        return content;
      }
    }
    
    // Convert human-readable text back to JSON
    function textToJson(text) {
      const lines = text.split('\n');
      const result = {
        multiple_choice_sentences: [],
        open_question: ''
      };
      
      let currentSection = null;
      let currentQuestion = null;
      
      for (let i = 0; i < lines.length; i++) {
        const line = lines[i].trim();
        
        if (line === '=== MULTIPLE CHOICE SENTENCES ===') {
          currentSection = 'multiple_choice';
          continue;
        } else if (line === '=== OPEN QUESTION ===') {
          currentSection = 'open_question';
          continue;
        }
        
        if (!line) continue;
        
        if (currentSection === 'multiple_choice') {
          // Check if it's a numbered sentence
          const sentenceMatch = line.match(/^\d+\.\s+(.+)$/);
          if (sentenceMatch) {
            if (currentQuestion) {
              result.multiple_choice_sentences.push(currentQuestion);
            }
            currentQuestion = {
              sentence: sentenceMatch[1],
              options: [],
              correct_option: 0
            };
          } else {
            // Check if it's an option
            const optionMatch = line.match(/^([a-d])\)\s+(.+?)(?:\s+\[CORRECT\])?$/);
            if (optionMatch && currentQuestion) {
              const optionText = optionMatch[2].trim();
              const isCorrect = line.includes('[CORRECT]');
              currentQuestion.options.push(optionText);
              if (isCorrect) {
                currentQuestion.correct_option = currentQuestion.options.length - 1;
              }
            }
          }
        } else if (currentSection === 'open_question') {
          if (!line.startsWith('(Guidance:')) {
            result.open_question += (result.open_question ? ' ' : '') + line;
          }
        }
      }
      
      // Add last question if exists
      if (currentQuestion) {
        result.multiple_choice_sentences.push(currentQuestion);
      }
      
      return result;
    }
    
    // Edit mode functionality
    const toggleEditBtn = document.getElementById('toggleEditBtn');
    const viewMode = document.getElementById('viewMode');
    const editMode = document.getElementById('editMode');
    const activityEditor = document.getElementById('activityEditor');
    const saveBtn = document.getElementById('saveBtn');
    const cancelBtn = document.getElementById('cancelBtn');
    
    toggleEditBtn.addEventListener('click', () => {
      viewMode.classList.add('hidden');
      editMode.classList.add('active');
      toggleEditBtn.style.display = 'none';
      
      // Load current content into editor (as readable text)
      if (currentData && currentData.generatedContent) {
        activityEditor.value = jsonToText(currentData.generatedContent);
        // Also build a structured editor for multiple choice content to allow mark/unmark
        try {
          const parsed = JSON.parse(currentData.generatedContent);
          buildStructuredEditor(parsed);
        } catch (e) {
          // ignore
          document.getElementById('structuredEditor').style.display = 'none';
        }
      }
    });
    
    saveBtn.addEventListener('click', () => {
      try {
        // If a structured editor is present, prefer its values to preserve markings
        const structured = document.getElementById('structuredEditor');
        let parsed;
        if (structured && structured.style.display !== 'none' && structured.dataset.source === 'multiple_choice') {
          parsed = readStructuredEditor();
        } else {
          // Parse the edited text back to JSON
          const editedText = activityEditor.value;
          parsed = textToJson(editedText);
        }

        // Update the current data
        currentData.generatedContent = JSON.stringify(parsed);
        
        // Save back to sessionStorage
        sessionStorage.setItem('activityData', JSON.stringify(currentData));
        
        // Update the view
        document.getElementById('activityContent').innerHTML = formatActivityContent(currentData.generatedContent);
        
        // Switch back to view mode
        viewMode.classList.remove('hidden');
        editMode.classList.remove('active');
        toggleEditBtn.style.display = 'block';
        
      } catch (error) {
        alert('Error saving changes. Please check your edits.\n\n' + error.message);
      }
    });
    
    cancelBtn.addEventListener('click', () => {
      // Switch back to view mode without saving
      viewMode.classList.remove('hidden');
      editMode.classList.remove('active');
      toggleEditBtn.style.display = 'block';
    });
    
    // PDF functionality
    let currentPdfId = null;
    
    // Generate unique activity ID based on activity timestamp
    function generateActivityId() {
      // Use the activity's creation timestamp to ensure uniqueness
      if (currentData && currentData.timestamp) {
        return `activity_${currentData.timestamp}`;
      }
      // Fallback to current timestamp
      return `activity_${Date.now()}`;
    }

    // Build a simple structured editor for multiple-choice content
    function buildStructuredEditor(parsedContent) {
      const container = document.getElementById('structuredEditor');
      container.innerHTML = '';

      const activity = parsedContent.tasks || parsedContent.exercises || parsedContent.activity_components || parsedContent;
      const multiChoice = activity.multiple_choice_blanks || activity.multiple_choice_sentences || parsedContent.multiple_choice_sentences || parsedContent.multiple_choice_blanks;
      if (!multiChoice || multiChoice.length === 0) {
        container.style.display = 'none';
        container.dataset.source = '';
        return;
      }

      container.style.display = 'block';
      container.dataset.source = 'multiple_choice';

      multiChoice.forEach((item, qIndex) => {
        const qDiv = document.createElement('div');
        qDiv.style.marginBottom = '12px';
        qDiv.innerHTML = `<div style="font-weight:700; margin-bottom:6px">${qIndex + 1}. ${item.sentence}</div>`;

        const ul = document.createElement('ul');
        ul.style.listStyle = 'none';
        ul.style.paddingLeft = '0';

        item.options.forEach((opt, optIndex) => {
          const li = document.createElement('li');
          li.style.padding = '6px';
          li.style.marginBottom = '6px';
          li.style.border = '1px solid #e6e6e6';
          li.style.borderRadius = '6px';
          li.dataset.optionIndex = optIndex;
          li.dataset.questionIndex = qIndex;

          const isCorrect = (typeof item.correct_option === 'number' && item.correct_option === optIndex) || (typeof item.correct_option === 'string' && item.correct_option === opt);

          const textSpan = document.createElement('span');
          textSpan.textContent = `${String.fromCharCode(97 + optIndex)}) ${opt}`;
          textSpan.style.marginRight = '10px';

          const btn = document.createElement('button');
          btn.type = 'button';
          btn.textContent = isCorrect ? 'Unmark' : 'Mark';
          btn.style.cssText = 'padding:4px 8px;border-radius:6px;border:1px solid #667eea;background:#fff;color:#667eea;cursor:pointer;font-weight:600;';
          btn.addEventListener('click', (e) => {
            e.preventDefault();
            toggleStructuredMark(qIndex, optIndex);
          });

          if (isCorrect) li.style.background = '#d4edda';

          li.appendChild(textSpan);
          li.appendChild(btn);
          ul.appendChild(li);
        });

        qDiv.appendChild(ul);
        container.appendChild(qDiv);
      });
    }

    function toggleStructuredMark(questionIndex, optIndex) {
      const container = document.getElementById('structuredEditor');
      const questionDivs = Array.from(container.children);
      const qDiv = questionDivs[questionIndex];
      if (!qDiv) return;
      const lis = qDiv.querySelectorAll('li');
      lis.forEach((li, idx) => {
        const btn = li.querySelector('button');
        if (idx === optIndex) {
          const marked = li.style.background === 'rgb(212, 237, 218)' || li.style.background === '#d4edda';
          if (marked) {
            li.style.background = '';
            btn.textContent = 'Mark';
          } else {
            li.style.background = '#d4edda';
            btn.textContent = 'Unmark';
          }
        } else {
          // unmark others
          li.style.background = '';
          const b = li.querySelector('button'); if (b) b.textContent = 'Mark';
        }
      });
    }

    function readStructuredEditor() {
      const container = document.getElementById('structuredEditor');
      const parsed = { multiple_choice_sentences: [] };
      if (!container || container.dataset.source !== 'multiple_choice') return parsed;

      const qDivs = Array.from(container.children);
      qDivs.forEach((qDiv) => {
        const sentence = qDiv.querySelector('div').textContent.replace(/^\d+\.\s*/, '').trim();
        const opts = [];
        let correctIdx = null;
        const lis = qDiv.querySelectorAll('li');
        lis.forEach((li, idx) => {
          const txt = li.querySelector('span').textContent.replace(/^[a-d]\)\s*/, '').trim();
          opts.push(txt);
          if (li.style.background === 'rgb(212, 237, 218)' || li.style.background === '#d4edda') {
            correctIdx = idx;
          }
        });
        const qObj = { sentence: sentence, options: opts, correct_option: correctIdx === null ? null : correctIdx };
        parsed.multiple_choice_sentences.push(qObj);
      });

      return parsed;
    }
    
    // Show status message
    function showMessage(message, type = 'info') {
      const statusMessage = document.getElementById('statusMessage');
      statusMessage.textContent = message;
      statusMessage.className = `message ${type}`;
      
      // Auto-hide success/info messages after 5 seconds
      if (type === 'success' || type === 'info') {
        setTimeout(() => {
          statusMessage.className = 'message';
        }, 5000);
      }
    }
    
    // Generate PDF button handler
    const generatePdfBtn = document.getElementById('generatePdfBtn');
    const downloadPdfBtn = document.getElementById('downloadPdfBtn');
    
    generatePdfBtn.addEventListener('click', async () => {
      if (!currentData || !currentData.generatedContent) {
        showMessage('No activity content available to generate PDF', 'error');
        return;
      }
      
      try {
        // Disable button and show loading state
        generatePdfBtn.disabled = true;
        generatePdfBtn.textContent = '⏳ Generating PDF...';
        showMessage('Generating PDF, please wait...', 'info');
        
        // Generate activity ID
        const activityId = generateActivityId();
        
        console.log('Generating PDF with data:', {
          activityId,
          contentLength: currentData.generatedContent ? currentData.generatedContent.length : 0,
          contentPreview: currentData.generatedContent ? currentData.generatedContent.substring(0, 100) : 'none'
        });
        
        // Send request to generate PDF
        const response = await fetch('/api/generate-pdf', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            activityContent: currentData.generatedContent,
            activityId: activityId,
            imageTitle: currentData.imageTitle || null,
            customImageBase64: currentData.customImageBase64 || null
          })
        });
        
        // Check if response is ok
        if (!response.ok) {
          const errorText = await response.text();
          console.error('Server error:', errorText);
          throw new Error(`Server returned ${response.status}: ${errorText}`);
        }
        
        const result = await response.json();
        console.log('PDF generation result:', result);
        
        if (result.success) {
          currentPdfId = result.pdfId;
          showMessage('PDF generated successfully! You can now download it.', 'success');
          
          // Show download button
          downloadPdfBtn.style.display = 'block';
          
          // Store PDF ID in sessionStorage for persistence
          sessionStorage.setItem('currentPdfId', currentPdfId);
        } else {
          showMessage(`Failed to generate PDF: ${result.message}`, 'error');
        }
        
      } catch (error) {
        console.error('Error generating PDF:', error);
        console.error('Error message:', error.message);
        console.error('Error stack:', error.stack);
        showMessage('Error: ' + error.message, 'error');
      } finally {
        // Re-enable button
        generatePdfBtn.disabled = false;
        generatePdfBtn.textContent = '📄 Generate PDF';
      }
    });
    
    // Download PDF button handler
    downloadPdfBtn.addEventListener('click', () => {
      if (!currentPdfId) {
        showMessage('No PDF available to download', 'error');
        return;
      }
      
      // Trigger download
      window.location.href = `/api/download-pdf/${currentPdfId}`;
      showMessage('Download started...', 'success');
    });
    
    // Check if PDF already exists on page load
    const storedPdfId = sessionStorage.getItem('currentPdfId');
    const lastActivityTimestamp = sessionStorage.getItem('lastActivityTimestamp');
    
    if (storedPdfId && currentData && lastActivityTimestamp === String(currentData.timestamp)) {
      // Only check for PDF if it's for the current activity
      fetch(`/api/check-pdf/${storedPdfId}`)
        .then(response => response.json())
        .then(result => {
          if (result.exists) {
            currentPdfId = storedPdfId;
            downloadPdfBtn.style.display = 'block';
            showMessage('A PDF for this activity is available for download', 'success');
          } else {
            // PDF expired or doesn't exist, clear the stored ID
            sessionStorage.removeItem('currentPdfId');
          }
        })
        .catch(error => {
          console.error('Error checking PDF:', error);
          sessionStorage.removeItem('currentPdfId');
        });
    } else {
      // Different activity or no stored PDF ID
      sessionStorage.removeItem('currentPdfId');
    }
  </script>
</body>
</html>
