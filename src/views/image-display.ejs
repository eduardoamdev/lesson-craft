<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Image Activity - Lesson Craft</title>
  <style>
    /* Reused conversation-display styles (kept concise) */
    *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:Segoe UI,Tahoma,Helvetica,Arial; background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);min-height:100vh;display:flex;justify-content:center;align-items:center;padding:20px}
    .container{background:white;border-radius:16px;padding:32px;max-width:900px;width:100%;box-shadow:0 20px 60px rgba(0,0,0,.2)}
    h1{color:#667eea;margin-bottom:8px;font-size:2em;text-align:center}
    .subtitle{color:#666;margin-bottom:20px;text-align:center}
    .section{margin-bottom:24px}
    .section h2{color:#764ba2;margin-bottom:12px}
    .question-item{margin-bottom:16px;padding:12px;background:#f7f7f7;border-radius:8px}
    .question-text{font-weight:600;margin-bottom:8px}
    .options-list{list-style:none;padding-left:0}
    .options-list li{padding:8px;margin-bottom:6px;background:#fff;border-radius:6px;border:2px solid transparent}
    .options-list li.correct{background:#d4edda;border-color:#27ae60;font-weight:600}
    .edit-controls{display:flex;gap:10px;margin-bottom:12px}
    .pdf-controls{display:flex;gap:10px;margin-bottom:12px}
    button {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: #fff;
      border: none;
      padding: 12px 22px;
      border-radius: 12px;
      cursor: pointer;
      font-size: 1.08em;
      font-weight: 600;
      box-shadow: 0 2px 8px rgba(102,126,234,0.10), 0 1.5px 4px rgba(118,75,162,0.08);
      transition: background 0.2s, box-shadow 0.2s, transform 0.1s;
    }
    button:hover, button:focus {
      background: linear-gradient(135deg, #5a67d8 0%, #6c3483 100%);
      box-shadow: 0 4px 16px rgba(102,126,234,0.18), 0 3px 8px rgba(118,75,162,0.13);
      outline: none;
      transform: translateY(-2px) scale(1.03);
    }
    button.secondary {
      background: #fff;
      color: #764ba2;
      border: 2px solid #764ba2;
      box-shadow: 0 1.5px 4px rgba(118,75,162,0.08);
    }
    button.secondary:hover, button.secondary:focus {
      background: #f3e9fa;
      color: #5a67d8;
      border-color: #5a67d8;
    }
    .message{padding:10px;border-radius:6px;margin-bottom:12px;display:none}
    .message.info{display:block;background:#d1ecf1;color:#0c5460}
    .action-buttons{display:flex;gap:12px;margin-top:18px}
    .action-buttons a{flex:1;text-decoration:none}
    img.preview{max-width:100%;border-radius:8px;margin-bottom:12px}
  </style>
</head>
<body>
  <div class="container">
      <div id="statusMessage" class="message"></div>
    <h1>🖼️ Generated Image Activity</h1>
    <div class="pdf-controls" style="display:flex; gap:10px; margin-bottom:20px;">
      <button id="generatePdfBtn" class="pdf-btn">📄 Generate PDF</button>
      <button id="downloadPdfBtn" class="download-btn" style="display:none">⬇️ Download PDF</button>
    </div>

    <div class="section">
      <h2>Activity</h2>
      <div id="activityContent">
        <% if (activity) { %>
          <% if (activity.customImageBase64) { %>
            <img class="preview" src="<%= activity.customImageBase64 %>" onerror="this.style.display='none';document.getElementById('imageErrorMsg').style.display='block';">
          <% } else if (activity.imageTitle) { %>
            <img class="preview" src="/data/images/<%= activity.imageTitle %>" onerror="this.style.display='none';document.getElementById('imageErrorMsg').style.display='block';">
          <% } %>
          <div id="imageErrorMsg" style="display:none;color:#c0392b;font-weight:600;margin-bottom:12px;">⚠️ Image could not be loaded.</div>
          <% if (activity.open_question) { %>
            <p style="margin-top:8px"><%= activity.open_question %></p>
          <% } else if (activity.description) { %>
            <p style="margin-top:8px"><%= activity.description %></p>
          <% } %>
        <% } else { %>
          <div>No activity data available.</div>
        <% } %>
      </div>
    </div>
    <div class="section">
      <h2>Comprehension Questions</h2>
      <div id="questionsContent">
        <% if (questions && questions.length) { %>
          <% questions.forEach(function(q, qIndex) { %>
            <div class="question-item">
              <div class="question-text"><%= (qIndex+1) + '. ' + (q.sentence || q.question) %></div>
              <ul class="options-list">
                <% (q.options || []).forEach(function(opt, optIndex) { %>
                  <li class="<%= (typeof q.correct_option === 'number' && q.correct_option === optIndex) ? 'correct' : '' %>">
                    <%= String.fromCharCode(97+optIndex) %>) <%= opt %>
                    <%= (typeof q.correct_option === 'number' && q.correct_option === optIndex) ? ' ✓' : '' %>
                  </li>
                <% }); %>
              </ul>
            </div>
          <% }); %>
        <% } else { %>
          <div>No questions available.</div>
        <% } %>
      </div>
    </div>

    <% if (activity && activity.open_question) { %>
      <div class="section">
        <h2>Open-Ended Question</h2>
        <div class="question-item">
          <div class="question-text"><%= activity.open_question %></div>
        </div>
      </div>
    <% } %>
    <div class="action-buttons">
      <a href="/image-edit"><button>✏️ Edit Image</button></a>
      <a href="/image-activity"><button class="secondary">← New Image</button></a>
      <a href="/"><button class="secondary">🏠 Home</button></a>
    </div>
  </div>

  <script>

    let currentData = null;
    let currentPdfId = null;
    let isEditMode = false;

    // Always set currentData from EJS variables if sessionStorage is empty
    const raw = sessionStorage.getItem('activityData');
    if (raw) {
      try {
        currentData = JSON.parse(raw);
      } catch (e) {
        console.error('Invalid activityData', e);
        currentData = null;
      }
    }
    if (!currentData) {
      try {
        currentData = JSON.parse('<%- JSON.stringify(activity || {}) %>');
        // Add generatedContent for PDF logic
        currentData.generatedContent = JSON.stringify({
          ...currentData,
          multiple_choice_sentences: <%- JSON.stringify(questions || []) %>,
          open_question: currentData.open_question || ''
        });
      } catch (e) {
        currentData = null;
      }
    }

    function extractJsonString(raw) {
      if (!raw) return null;
      // Remove triple backticks and leading descriptive text
      let s = String(raw).trim();
      s = s.replace(/^```(?:json)?\s*/i, '');
      s = s.replace(/\s*```$/i, '');

      // If the string contains a JSON object, try to find the first {...} block
      const firstBrace = s.indexOf('{');
      const lastBrace = s.lastIndexOf('}');
      if (firstBrace !== -1 && lastBrace !== -1 && lastBrace > firstBrace) {
        return s.slice(firstBrace, lastBrace + 1);
      }

      return s;
    }

    function parseGenerated() {
      if (!currentData) return {};
      const raw = currentData.generatedContent || '';
      const jsonStr = extractJsonString(raw);
      if (!jsonStr) return {};
      try { return JSON.parse(jsonStr); } catch (e) {
        console.error('Failed to parse generatedContent JSON:', e, jsonStr);
        return {};
      }
    }



    function displayQuestions() {
      const container = document.getElementById('questionsContent');
      const parsed = parseGenerated();
      const multi = parsed.multiple_choice_sentences || parsed.multiple_choice_blanks || [];
      let html = '';
      multi.forEach((q, qIndex) => {
        html += `<div class="question-item" data-index="${qIndex}">`;
        const questionText = q.sentence || q.question || '';
        const editableQ = isEditMode ? 'contenteditable="true"' : '';
        html += `<div class="question-text" ${editableQ} data-field="question">${qIndex+1}. ${questionText}</div>`;
        html += '<ul class="options-list">';
        (q.options || []).forEach((opt, optIndex) => {
          const isCorrect = (typeof q.correct_option === 'number' && q.correct_option === optIndex) || (typeof q.correct_option === 'string' && q.correct_option === opt);
          const optionTextEditable = isEditMode ? 'contenteditable="true"' : '';
          html += `<li class="${isCorrect ? 'correct' : ''}" data-field="option" data-option-index="${optIndex}">`;
          html += `<span class="option-label">${String.fromCharCode(97+optIndex)})</span> `;
          html += `<span class="option-text" ${optionTextEditable}>${opt}</span>`;
          html += `<span class="option-check">${isCorrect ? ' ✓' : ''}</span>`;
          html += `</li>`;
        });
        html += '</ul></div>';
      });

      container.innerHTML = html;
      attachOptionControls();
    }

    function attachOptionControls() {
      const questionItems = document.querySelectorAll('#questionsContent .question-item');
      questionItems.forEach((item, qIndex) => {
        const optionElems = item.querySelectorAll('[data-field="option"]');
        optionElems.forEach((optionElem, optIndex) => {
          const existing = optionElem.querySelector('.mark-btn'); if (existing) existing.remove();
          if (isEditMode) {
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'mark-btn';
            btn.style.cssText = 'margin-left:10px;padding:4px 8px;border-radius:6px;border:1px solid #667eea;background:#fff;color:#667eea;cursor:pointer;font-weight:600;';
            btn.textContent = optionElem.classList.contains('correct') ? 'Unmark' : 'Mark';
            btn.addEventListener('click', (e) => { e.preventDefault(); e.stopPropagation(); toggleOptionCorrectness(qIndex, optIndex); });
            optionElem.appendChild(btn);
          }
        });
      });
    }

    function toggleOptionCorrectness(questionIndex, optIndex) {
      const questionItem = document.querySelector(`#questionsContent .question-item[data-index="${questionIndex}"]`);
      if (!questionItem) return;
      const optionElems = questionItem.querySelectorAll('[data-field="option"]');
      const target = optionElems[optIndex]; if (!target) return;
      const textSpan = target.querySelector('.option-text');
      const checkSpan = target.querySelector('.option-check');
      const already = target.classList.contains('correct');
      if (already) {
        target.classList.remove('correct');
        if (checkSpan) checkSpan.textContent = '';
      } else {
        optionElems.forEach((el, idx) => {
          const cs = el.querySelector('.option-check');
          if (idx === optIndex) {
            el.classList.add('correct');
            if (cs) cs.textContent = ' ✓';
          } else {
            el.classList.remove('correct');
            if (cs) cs.textContent = '';
          }
        });
      }
      attachOptionControls();
    }

    function toggleEditMode() {
      isEditMode = !isEditMode;
      const editModeBtn = document.getElementById('editModeBtn');
      const saveChangesBtn = document.getElementById('saveChangesBtn');
      const pdfControlsEl = document.querySelector('.pdf-controls');
      if (isEditMode) { editModeBtn.textContent = '👁️ View Mode'; saveChangesBtn.style.display='inline-block'; if(pdfControlsEl) pdfControlsEl.style.display='none'; showMessage('Edit mode enabled. Click to edit.','info'); }
      else { editModeBtn.textContent = '✏️ Edit Mode'; saveChangesBtn.style.display='none'; if(pdfControlsEl) pdfControlsEl.style.display='flex'; showMessage('Edit mode disabled.','info'); }
      displayActivity(); displayQuestions();
    }

    function saveChanges() {
      try {
        const parsed = parseGenerated();
        const qItems = document.querySelectorAll('#questionsContent .question-item');
        parsed.multiple_choice_sentences = [];
        qItems.forEach((item, qIndex) => {
          const qTextEl = item.querySelector('[data-field="question"]');
          const qText = qTextEl ? qTextEl.textContent.replace(/^\d+\.\s*/,'').trim() : '';
          const opts = [];
          let correctIdx = null;
          const optionEls = item.querySelectorAll('[data-field="option"]');
          optionEls.forEach((optEl, idx) => {
            const textSpan = optEl.querySelector('.option-text');
            const txt = textSpan ? textSpan.textContent.trim() : optEl.textContent.replace(/^[a-z]\)\s*/,'').replace(/\s*✓\s*$/,'').trim();
            opts.push(txt);
            if (optEl.classList.contains('correct')) correctIdx = idx;
          });
          parsed.multiple_choice_sentences.push({ sentence: qText, options: opts, correct_option: correctIdx });
        });

        currentData.generatedContent = JSON.stringify(parsed);
        sessionStorage.setItem('activityData', JSON.stringify(currentData));
        // Clear old PDF id for this activity
        sessionStorage.removeItem('currentPdfId');
        document.getElementById('downloadPdfBtn').style.display='none';
        isEditMode = false; toggleEditMode();
        showMessage('Changes saved successfully!','success');
      } catch (err) { console.error(err); showMessage('Error saving changes: '+err.message,'error'); }
    }

    function showMessage(msg, type='info'){
      const el = document.getElementById('statusMessage'); el.textContent = msg; el.className = 'message '+type; if(type==='info'){ setTimeout(()=>{ el.className='message'; },4000); }
    }

    // PDF generation (generic)
    // Embed activity and questions as JSON for JS access
    const ejsActivityJSON = '<%- JSON.stringify(activity || {}) %>';
    const ejsQuestionsJSON = '<%- JSON.stringify(questions || []) %>';

    const downloadBtn = document.getElementById('downloadPdfBtn');
    // Always hide download button on page load
    if (downloadBtn) downloadBtn.style.display = 'none';

    document.getElementById('generatePdfBtn').addEventListener('click', async () => {
      const btn = document.getElementById('generatePdfBtn');
      btn.disabled = true;
      btn.textContent = '⏳ Generating PDF...';
      showMessage('Generating PDF...', 'info');
      try {
        let activityContent = null;
        let activityId = null;
        let imageTitle = null;
        let customImageBase64 = null;
        if (currentData && currentData.generatedContent) {
          activityContent = currentData.generatedContent;
          activityId = `activity_${currentData.timestamp}`;
          imageTitle = currentData.imageTitle || null;
          customImageBase64 = currentData.customImageBase64 || null;
        } else {
          let ejsActivity = {};
          let ejsQuestions = [];
          try {
            ejsActivity = JSON.parse(ejsActivityJSON);
            ejsQuestions = JSON.parse(ejsQuestionsJSON);
          } catch (e) {}
          activityContent = JSON.stringify({
            ...ejsActivity,
            multiple_choice_sentences: ejsQuestions,
            open_question: ejsActivity.open_question || ''
          });
          activityId = `activity_${Date.now()}`;
          imageTitle = ejsActivity.imageTitle || null;
          customImageBase64 = ejsActivity.customImageBase64 || null;
        }
        const response = await fetch('/api/generate-pdf', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ activityContent, activityId, imageTitle, customImageBase64 })
        });
        if (!response.ok) throw new Error('PDF generation failed');
        const result = await response.json();
        if (result.success) {
          currentPdfId = result.pdfId;
          sessionStorage.setItem('currentPdfId', currentPdfId);
          if (downloadBtn) downloadBtn.style.display = 'inline-block';
          showMessage('PDF generated successfully!', 'success');
        } else throw new Error(result.message || 'Failed');
      } catch (err) {
        console.error(err);
        showMessage('Error: ' + err.message, 'error');
      } finally {
        btn.disabled = false;
        btn.textContent = '📄 Generate PDF';
      }
    });

    if (downloadBtn) downloadBtn.addEventListener('click', () => {
      const id = sessionStorage.getItem('currentPdfId');
      if (id) window.location.href = `/api/download-pdf/${id}`;
    });

    const editModeBtn = document.getElementById('editModeBtn');
    if (editModeBtn) editModeBtn.addEventListener('click', toggleEditMode);
    const saveChangesBtn = document.getElementById('saveChangesBtn');
    if (saveChangesBtn) saveChangesBtn.addEventListener('click', saveChanges);

    // displayQuestions(); // Only call in edit mode
  </script>
</body>
</html>
